/* pages/teacher/school/index.wxss */

@import '../../common/common.wxss';
.container {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  height: 100%;
}
.header {
  display: flex;
  align-items: center;
  margin: 10px;
  padding: 10px;
  border-radius: 4px;
  background: linear-gradient(180deg, #fcfcfc 50%, #94b7f7 99%);
  box-sizing: border-box;
}

.appointmentTitle {
  font-size: 19px;
}

.avatar {
  width: 50px;
  height: 50px;
  border-radius: 50%;
}

.info {
  margin-left: 10px;
}

.name {
  font-size: 16px;
}

.teacher-id {
  font-size: 14px;
}

.planButton{
  height: 34px;
  border-radius: 0rpx;
  width: 100px;
  background-image: linear-gradient(270deg, #2262E6 0%, #0DC7CE 100%);
  font-family: PingFangSC-Regular;
  font-size: 30rpx;
  color: #FFFFFF;
  line-height: 60rpx;
  text-align: center;
  position: absolute;
  right: 15px;
  bottom: 13px;
}