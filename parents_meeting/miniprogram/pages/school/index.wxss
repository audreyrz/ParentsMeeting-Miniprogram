@import '../common/common.wxss';
.container {
  display: flex;
  flex-direction: column;
  align-items: stretch;
  justify-content: flex-start;
  height: 100%;
}
.header {
  display: flex;
  align-items: center;
  margin: 10px;
  padding: 10px;
  border-radius: 4px;
  background: linear-gradient(180deg, #fcfcfc 50%, #94b7f7 99%);
  box-sizing: border-box;
}

.avatar {
  width: 50px;
  height: 50px;
  border-radius: 50%;
}

.info {
  margin-left: 10px;
}

.name {
  font-size: 16px;
}

.student-id {
  font-size: 14px;
}

.board {
  height: 150px;
  border: 1px solid #99C0FF;
  font-family: PingFangSC-Regular;
  font-size: 32rpx;
  color: #206BED;
  padding: 18rpx 20rpx;
  margin: 10px;
  position: relative;
}

.reservation {
  height: 200px;
  background-color: #e0e0e0;
  margin: 10px;
}

.schedule {
  display: flex;
  height: 150px;
  margin: 10px;
}

.map {
  flex: 1;
  border: 1px solid #99C0FF;
  font-family: PingFangSC-Regular;
  font-size: 32rpx;
  color: #206BED;
  padding: 18rpx 20rpx;
}
.previewImage{
  width: 100%;
  height: 120px;
  margin-top: 5px;
}
.plan {
  flex: 1;
  display: flex;
  flex-direction: column;
  border: 1px solid #99C0FF;
  font-family: PingFangSC-Regular;
  font-size: 32rpx;
  color: #206BED;
  padding: 18rpx 20rpx;
}
.planButton{
  height: 34px;
  border-radius: 0rpx;
  width: 100px;
  background-image: linear-gradient(270deg, #2262E6 0%, #0DC7CE 100%);
  font-family: PingFangSC-Regular;
  font-size: 30rpx;
  color: #FFFFFF;
  line-height: 60rpx;
  text-align: center;
  position: absolute;
  right: 20px;
  bottom: 20px;
}