/* pages/meeting/index.wxss */

@import '../common/common.wxss';

.page{
  background-color: var(--weui-BG-2);
  height: 100%;
  padding: 20rpx;
}
button{
  height: 80rpx;
  border-radius: 0rpx;
  min-width: 50%;
  background-image: linear-gradient(270deg, #2262E6 0%, #0DC7CE 100%);
  font-family: PingFangSC-Regular;
  font-size: 32rpx;
  color: #FFFFFF;
  line-height: 48rpx;
  margin-top: 120rpx;
}
.weui-tabs-bar__wrp {
  border-bottom: 1px solid var(--weui-BG-2);
  margin-top: 10px;
}

.weui-tabs-swiper {
  width: 100%;
  height: 100%;

  background-color: var(--weui-BG-2);

}

.tab-content {
  /* height: 100px; */
  width: 100%;
  display: flex;
  /* flex-direction: column;
  justify-content: center;
  align-items: center; */
  box-sizing: border-box;
  /* padding: 20px; */
}

.weui-tabs-bar__title {
  margin: 0px 10px;
}

.tab-bar-title__selected {
  font-size: 20px;
  font-weight: bold;
}
.item-title {
  margin: 10px 10px 5px;
  font-size: 18px;
  width: 100%;
}
.item-desc {
  margin: 5px 10px 0;
  width: 100%;
  color: var(--weui-FG-1)
}
.weui-tabs-bar__item {
  background-color: var(--weui-BG-2) !important;
  color: var(--weui-FG-0) !important;
}
.bzrName{
  display: inline-flex;
}
.itemList{
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  margin-top: 10px;
}
.itemBorder{
  border: 1px solid #99C0FF;
  width: fit-content;
  line-height: 20px;
  padding:0px 5px;
  margin-right: 5px;
  margin-bottom: 4px;
  cursor: pointer;
  position: relative;
}
.teacherNum{
  margin-left: 20px;
  margin-bottom: 10px;
  width: 100%;
}
.active{
  background-color: #99C0FF;
  color: #FFFFFF;
}
.ml15{margin-left: 15px;}
.mb10{margin-bottom: 10px;}
.selectedArea{
  border: 1px solid #99C0FF;
  background-color: #edeff1;
  padding: 15px 0px;
  width: 95%;
  height: auto;
  max-height: 100px;
  display: flex;
  flex-direction: row;
  flex-wrap: wrap;
  overflow-y: scroll;
}
.delete-btn{
  position: absolute;
  background-color: #a6a9ad;
  top: -10px;
  right: -15px;
  font-size: 14px;
  width: 20px;
  height: 20px;
  border-radius: 50%;
  text-align: center;
  opacity: 0.5;
}